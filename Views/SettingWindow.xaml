<hc:Window
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:hc="https://handyorg.github.io/handycontrol"
  xmlns:local="clr-namespace:SplusXBTMeter"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  x:Class="SplusXBTMeter.SettingWindow"
  mc:Ignorable="d"
  Icon="pack://application:,,,/App.ico"
  Title="设置"
  Height="506"
  Width="400"
  HorizontalAlignment="Center"
  WindowStartupLocation="CenterScreen"
>
  <!-- 新增：窗口默认屏幕居中 -->
  <!-- 修复1：改为水平填充，取消固定宽度，让容器铺满窗口 -->
  <hc:TransitioningContentControl HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
    <!-- 修复2：删除固定Width，水平填充，取消内边距挤压 -->
    <TabControl
      SelectedIndex="0"
      Style="{StaticResource TabControlInLine}"
      Height="auto"
      HorizontalAlignment="Stretch"
      Margin="5"
      BorderThickness="0,0,0,1"
    >
      <!-- 统一外边距，美观 -->
      <TabItem Header="设置" FontSize="16">
        <StackPanel>
          <hc:Divider
            Content="样式设置"
            HorizontalContentAlignment="Left"
            Height="24"
            Margin="10,5,10,0"
          />

          <ComboBox
            Style="{StaticResource ComboBoxExtend}"
            hc:DropDownElement.ConsistentWidth="False"
            x:Name="SkinComboBox"
            Height="58"
            Margin="10,5,10,0"
            hc:InfoElement.Title="任务栏样式"
            ItemsSource="{Binding SkinList}"
            SelectedValuePath="."
            SelectedValue="{Binding SelectedSkin, Mode=TwoWay}"
          >
            <!-- ✅ 使用 "." 表示当前项本身 -->
            <!-- 下拉选项 -->
          </ComboBox>

          <hc:Divider
            Content="显示设置"
            HorizontalContentAlignment="Left"
            Height="24"
            Margin="10,5,10,0"
          />
          <CheckBox
            x:Name="IsShowTaskBar"
            Content="显示任务栏窗口(还没做)"
            Margin="10,5,10,0"
            VerticalAlignment="Top"
            Height="24"
            Click="IsShowTaskBar_Checked"
          />
          <CheckBox
    x:Name="IsShowMain"
    Content="显示主窗口(还没做)"
    Margin="10,5,10,0"
    VerticalAlignment="Top"
    Height="24"
    Click="IsShowMain_Checked"
  />
                    <CheckBox
    x:Name="IsShowNoConn"
    Content="显示断连设备"
    Margin="10,5,10,0"
    VerticalAlignment="Top"
    Height="24"
    Click="IsShowNoConn_Checked" 
    IsChecked="{Binding IsShowNoConn}"

  />
                    <hc:Divider
            Content="启动设置"
            HorizontalContentAlignment="Left"
            Height="24"
            Margin="10,5,10,0"
          />
          <CheckBox
            x:Name="IsStartup"
            Content="开机启动"
            Margin="10,5,10,0"
            VerticalAlignment="Top"
            Height="24"
            Click="IsStartup_Checked"
                  IsChecked="{Binding IsStartup}"
          />
        </StackPanel>
      </TabItem>
      <TabItem Header="设备自定义" FontSize="16">
        <ListBox
          ItemsSource="{Binding BluetoothDevices}"
          MouseDoubleClick="ListBox_MouseDoubleClick"
          Height="417"
          Margin="5,5,5,5" Padding="2,2,2,2"
        >
          <ListBox.ItemTemplate>
            <DataTemplate>
              <!-- 垂直布局 -->
              <StackPanel Margin="3,0">
                                <TextBlock FontSize="14" FontWeight="Medium">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <!-- 默认：未连接 -->
                                            <Setter Property="Text">
                                                <Setter.Value>
                                                    <MultiBinding StringFormat="设备：{0}  状态：⛓‍💥">
                                                        <Binding Path="Name" />
                                                    </MultiBinding>
                                                </Setter.Value>
                                            </Setter>

                                            <!-- 👉 当 IsConnected = True 时显示 已连接 -->
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                    <Setter Property="Text">
                                                        <Setter.Value>
                                                            <MultiBinding StringFormat="设备：{0}  状态：🔗">
                                                                <Binding Path="Name" />
                                                            </MultiBinding>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock
                  Text="{Binding Mac, StringFormat={}Mac地址：{0}}"
                  FontSize="12"
                  Foreground="Gray"
                  Margin="0,2,0,0"
                />
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </TabItem>
    </TabControl>
  </hc:TransitioningContentControl>
</hc:Window>
