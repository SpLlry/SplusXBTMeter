<hc:Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol" 
        x:Class="SplusXBTMeter.MainWindow"
        mc:Ignorable="d"
        Title="SplusXBTMeter" 
        Width="210"
        Height="214"
        ShowInTaskbar="True"
        BorderThickness="0"
        WindowStartupLocation="CenterScreen"
        Topmost="False"
        Icon="pack://application:,,,/App.ico"
        ResizeMode="NoResize" HorizontalAlignment="Center">

    <!-- 自定义展示内容：网速+CPU使用率 -->
    <Grid HorizontalAlignment="Center" >
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="44"/>
            <RowDefinition Height="44"/>
            <RowDefinition Height="44"/>
        </Grid.RowDefinitions>

        <Label 
            Content="检测到应用已启动,您可以" Margin="24,0,20,0"  Background="Transparent" 
            BorderThickness="0,0,0,0" HorizontalAlignment="Stretch" Height="28"/>
        <Button 
            Content="设置" 
              RenderTransformOrigin="-0.223,0.085" 
            Margin="22,8,22,8"  VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Click="Button_Click" Grid.Row="1"/>

        <Button 
            Content="重启应用" 
            RenderTransformOrigin="-0.223,0.085" 
            Margin="24,8,20,8"  VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Grid.Row="2"/>
        <Button 
            Content="退出" 
            RenderTransformOrigin="-0.223,0.085" 
            Margin="24,10,20,0"  VerticalAlignment="Top" HorizontalAlignment="Stretch" Grid.Row="3" Click="Button_Click_1"/>
 


    </Grid>
    
</hc:Window>