<hc:Window 
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    x:Class="SplusXBTMeter.DeviceDiyWindow"
    Title="编辑设备属性" 
    Height="274" 
    Width="300"
    WindowStartupLocation="CenterOwner"
    Icon="app.ico"
    ResizeMode="NoResize">
    <!-- 🔥 用 Grid 自动布局，彻底解决显示不全 -->
    <Grid Margin="15,15,15,10" >
        <Grid.RowDefinitions>
            <RowDefinition Height="55"/>
            <!-- MAC地址 -->
            <RowDefinition Height="55"/>
            <!-- 设备名称 -->
            <RowDefinition Height="55"/>
            <!-- 显示设备 -->
            <RowDefinition Height="55"/>
            <!-- 空白填充 -->
            <RowDefinition Height="55"/>
            <!-- 按钮栏 -->
        </Grid.RowDefinitions>

        <!-- MAC地址 -->
        <hc:TextBox 
            Grid.Row="0"
            x:Name="Address" 
            IsEnabled="False"
            hc:TitleElement.Title="MAC地址"
            Margin="0 5 0 0"
            />

        <!-- 设备名称 -->
        <hc:TextBox
            Grid.Row="1"
            x:Name="Name" 
            hc:TitleElement.Title="设备名称"
            Margin="0,5,0,0"/>

        <!-- 显示设备 -->
        <CheckBox 
            Grid.Row="2"
            x:Name="IsShowDevice" 
            Content="显示设备" 
            Margin="0 5 0 0"
            Style="{StaticResource CheckBoxBaseStyle}"
            FontSize="14"/>

        <!-- 取消 / 保存 按钮 -->
        <StackPanel 
            Grid.Row="3"
            Orientation="Horizontal"
            Margin="187,2,3,0">
            <Button 
                Content="保存" Click="Btn_Save" Width="80" 
                 Style="{StaticResource ButtonSuccess}"
                    RenderTransformOrigin="0.2,0.581" 
                    />
        </StackPanel>
    </Grid>
</hc:Window>