<hc:Window x:Class="BTBatteryDisplayApp.TaskBarWindow"
          xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
          xmlns:d="http://schemas.microsoft.com/expression/blend/2006"
          xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
          xmlns:hc="https://handyorg.github.io/handycontrol"
          xmlns:local="clr-namespace:BTBatteryDisplayApp"
          mc:Ignorable="d"
          Title="TaskBarWindow" Height="46" Width="200"
          WindowStyle="None"
          AllowsTransparency="True"
          Background="Transparent"
          ShowInTaskbar="False"
          BorderThickness="0"
          Topmost="False"
          Icon="app.ico"
          ResizeMode="NoResize">

    <hc:Window.Resources>
        <!-- 水波纹样式（无改动） -->
        <Style x:Key="WaveProgressBarStyle" TargetType="hc:WaveProgressBar" BasedOn="{StaticResource ProgressBarWarningWave}">
            <Setter Property="ShowText" Value="False"/>
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsWaveEffect, RelativeSource={RelativeSource AncestorType=hc:Window}}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 圆环样式（无改动） -->
        <Style x:Key="CircleProgressBarStyle" TargetType="hc:CircleProgressBar" BasedOn="{StaticResource {x:Type hc:CircleProgressBar}}">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsWaveEffect, RelativeSource={RelativeSource AncestorType=hc:Window}}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </hc:Window.Resources>

    <Grid Height="46" VerticalAlignment="Center">
        <ItemsControl 
            ItemsSource="{Binding BluetoothDevices}"
            Height="46"
            VerticalAlignment="Center">

            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Margin="5,0,0,0"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <hc:SimplePanel Height="46" Width="46" Margin="0,0,5,0">

                        <!-- 🔥 核心：仅新增Grid，宽高/边距/对齐 100%复刻原控件 -->
                        <Grid 
                            Width="34" 
                            Height="34" 
                            Margin="0,2,6,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top">

                            <!-- ✅ 圆环：完全保留你原始的所有属性，尺寸/位置零变化 -->
                            <hc:CircleProgressBar 
                                Style="{StaticResource CircleProgressBarStyle}"
                                Background="#FFC8CACA"
                                Width="34" 
                                Height="34" 
                                FontSize="8"
                                BorderBrush="White"
                                ShowText="False" 
                                Value="{Binding Battery, FallbackValue=0, TargetNullValue=0}"/>

                            <!-- ✅ 水波纹：完全保留你原始的所有属性 -->
                            <hc:WaveProgressBar
                                Style="{StaticResource WaveProgressBarStyle}"
                                Value="{Binding Battery, FallbackValue=0}" 
                                Width="34" 
                                Height="34"
                                WaveThickness="3">
                                <hc:WaveProgressBar.WaveFill>
                                    <SolidColorBrush Color="#309430" Opacity="0.8"/>
                                </hc:WaveProgressBar.WaveFill>
                            </hc:WaveProgressBar>

                            <!-- ✅ 文字：完美居中，不影响任何控件尺寸 -->
                            <TextBlock 
                                Text="{Binding Battery, StringFormat={}{0}%}"
                                FontSize="8"
                                Foreground="White"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>

                        </Grid>

                        <!-- 设备名称（无改动） -->
                        <Label 
                            Height="10" Width="46"
                            Background="Transparent"
                            FontSize="8" 
                            BorderThickness="0"
                            Padding="0"
                            VerticalAlignment="Top" 
                            Margin="0,36,0,0"
                            Content="{Binding Name, FallbackValue=未知设备}"/>
                    </hc:SimplePanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</hc:Window>