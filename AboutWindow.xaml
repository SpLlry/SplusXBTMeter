<hc:Window
  x:Class="SplusXBTMeter.AboutWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:hc="https://handyorg.github.io/handycontrol"
  Title="关于"
  Width="407"
  Height="263"
  WindowStartupLocation="CenterScreen"
  ResizeMode="NoResize"

  Icon="/app.ico"
>
    <StackPanel
    VerticalAlignment="Top"
    HorizontalAlignment="Center"
    Margin="0,10,0,0"
    Height="225"
    Width="387"
  >
        <!-- 软件图标 -->

        <!-- 软件名称 -->
        <StackPanel
      Orientation="Horizontal"
      HorizontalAlignment="Center"
      VerticalAlignment="Center"
      Margin="0,10"
    >
            <Image
        Width="24"
        Height="24"
        Source="/app.ico"
        Stretch="Uniform"
        VerticalAlignment="Center"
      />
            <TextBlock
        Text="SplusXBTMeter v1.0.0"
        FontSize="24"
        FontWeight="Bold"
        Margin="5,0,0,0"
        VerticalAlignment="Center"
      />
        </StackPanel>

        <!-- 分隔线 -->
        <hc:Divider Margin="0,10" />
        <!-- 描述信息 -->
        <TextBlock
      Text="一款轻量级蓝牙设备电量实时监控工具"
      FontSize="14"
      Margin="0,10"
      HorizontalAlignment="Center"
      VerticalAlignment="Center"
    />

        <TextBlock
      Text="支持任务栏嵌入、系统托盘、多设备管理"
      FontSize="14"
      HorizontalAlignment="Center"
      Margin="0,10"
    />

        <!-- 版权信息 -->
        <TextBlock
      Text="Copyright© 2026 By SPlusx"
      FontSize="12"
      Margin="0,10"
      HorizontalAlignment="Center"
    />

        <TextBlock
      FontSize="12"
      Foreground="{DynamicResource TextThirdBrush}"
      Margin="0,10"
      HorizontalAlignment="Center"
    >
      <Hyperlink NavigateUri="https://github.com/SpLlry/SplusXBTMeter">
GitHub
</Hyperlink>
      <Hyperlink NavigateUri="https://gitee.com/SpLlry/SplusXBTMeter">
Gitee
</Hyperlink>
      <Hyperlink NavigateUri="https://github.com/SpLlry/SplusXBTMeter">
打赏作者
</Hyperlink>
        </TextBlock>
    </StackPanel>
</hc:Window>
